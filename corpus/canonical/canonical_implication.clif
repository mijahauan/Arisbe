(cl:comment "Canonical example of implication (if-then)")
(cl:comment "Logical form: ¬(P ∧ ¬Q)")
(cl:comment "Source: EGRF v3.0 Corpus")

(cl:text
  (cl:imports "http://www.example.org/ontology/canonical-examples")
  
  (cl:comment "Implication: If P, then Q")
  (implies P Q)
  
  (cl:comment "Equivalent form using negation and conjunction")
  (not (and P (not Q)))
)

