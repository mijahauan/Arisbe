(cl:comment "CLIF representation of Peirce's man-mortal implication from CP 4.394")
(cl:comment "Source: Peirce, C.S. (1932). Collected Papers, Vol. 4, §4.394. Harvard University Press.")
(cl:comment "English: 'If anything is a man, then it is mortal.'")
(cl:comment "Logical form: ∀x(Man(x) → Mortal(x))")

(cl:module peirce_cp_4_394_man_mortal

(cl:forall (x)
  (cl:if (Man x) (Mortal x)))

)

